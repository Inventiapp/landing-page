	<script>
		document.addEventListener("DOMContentLoaded", function () {
			const toggle = document.getElementById("pricing-toggle")!;
			const toggleCircle = document.getElementById("toggle-circle")!;
			const monthlyLabel = document.getElementById("monthly-label")!;
			const annualLabel = document.getElementById("annual-label")!;

			// Price elements
			const basicPeriod = document.getElementById("basic-period")!;
			const emprendedorPrice =
				document.getElementById("emprendedor-price")!;
			const emprendedorPeriod =
				document.getElementById("emprendedor-period")!;
			const emprendedorAnnualPrice = document.getElementById(
				"emprendedor-annual-price",
			)!;
			const empresaPrice = document.getElementById("empresa-price")!;
			const empresaPeriod = document.getElementById("empresa-period")!;
			const empresaAnnualPrice = document.getElementById(
				"empresa-annual-price",
			)!;

			let isAnnual = false;

			function updatePricing() {
				if (isAnnual) {
					// Switch to Annual
					toggleCircle.style.transform = "translateX(24px)";
					toggle.children[0].classList.add("bg-[#ffa22a]");
					toggle.children[0].classList.remove("bg-gray-300");
					monthlyLabel.classList.add("opacity-60");
					annualLabel.classList.remove("opacity-60");

					// Update prices
					basicPeriod.textContent = "/ AÑO";
					emprendedorPrice.textContent = "S/470";
					emprendedorPeriod.textContent = "/ AÑO";
					emprendedorAnnualPrice.textContent = "S/588";
					emprendedorAnnualPrice.classList.remove("hidden");
					empresaPrice.textContent = "S/1,910";
					empresaPeriod.textContent = "/ AÑO";
					empresaAnnualPrice.textContent = "S/2,388";
					empresaAnnualPrice.classList.remove("hidden");
				} else {
					// Switch to Monthly
					toggleCircle.style.transform = "translateX(0px)";
					toggle.children[0].classList.remove("bg-[#ffa22a]");
					toggle.children[0].classList.add("bg-gray-300");
					monthlyLabel.classList.remove("opacity-60");
					annualLabel.classList.add("opacity-60");

					// Update prices
					basicPeriod.textContent = "/ MES";
					emprendedorPrice.textContent = "S/49";
					emprendedorPeriod.textContent = "/ MES";
					emprendedorAnnualPrice.classList.add("hidden");
					empresaPrice.textContent = "S/199";
					empresaPeriod.textContent = "/ MES";
					empresaAnnualPrice.classList.add("hidden");
				}
			}

			function togglePricing() {
				isAnnual = !isAnnual;
				updatePricing();
			}

			toggle.addEventListener("click", togglePricing);
			monthlyLabel.addEventListener("click", function () {
				if (isAnnual) togglePricing();
			});
			annualLabel.addEventListener("click", function () {
				if (!isAnnual) togglePricing();
			});

		updatePricing();
	});

	// Toggle details dropdown for mobile
	function toggleDetails(plan: string) {
		const details = document.getElementById(plan + '-details');
		const chevron = document.getElementById(plan + '-chevron');
		
		if (details && chevron) {
			const isHidden = details.classList.contains('hidden');
			
			if (isHidden) {
				details.classList.remove('hidden');
				details.classList.add('flex');
				chevron.style.transform = 'rotate(180deg)';
			} else {
				details.classList.add('hidden');
				details.classList.remove('flex');
				chevron.style.transform = 'rotate(0deg)';
			}
		}
	}

	// Make toggleDetails globally available
	(window as any).toggleDetails = toggleDetails;
</script>
